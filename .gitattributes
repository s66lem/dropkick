# Ensure Unix line endings for files consumed on the Raspberry Pi,
# regardless of the host that committed them. CRLF here breaks shebangs
# and systemd unit parsing.
*.sh            text eol=lf
*.service       text eol=lf
*.env           text eol=lf
*.properties    text eol=lf
*.in            text eol=lf
*.milk          text eol=lf
dropkick.env    text eol=lf
