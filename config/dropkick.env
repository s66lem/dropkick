# Dropkick runtime environment — the single source of truth for configuration.
# Sourced by the systemd service AND by scripts/{bootstrap,sync-config}.sh, which
# render projectMSDL.properties from these values. After editing, run
# scripts/sync-config.sh and restart the service.
#
# Copy to dropkick.local.env to override without touching version control.

# Install prefix used by the build/sync scripts
DROPKICK_PREFIX="${HOME}/.local"

# Preset / texture library roots and the active pack
DROPKICK_PRESET_ROOT="${HOME}/.local/share/dropkick/presets"
DROPKICK_TEXTURE_ROOT="${HOME}/.local/share/dropkick/textures"
DROPKICK_PRESET_PACK="cream-of-the-crop"

# Web assets served by the remote
DROPKICK_WEB_ROOT="${HOME}/.local/share/dropkick/remote"

# Audio capture device (empty = default/first device). Generic: any host device.
DROPKICK_AUDIO_SOURCE=""

# Phone remote
DROPKICK_REMOTE_PORT="8080"
DROPKICK_REMOTE_TOKEN=""

# Display for the HDMI output (X11). On Wayland, set DROPKICK via dropkick.local.env:
#   WAYLAND_DISPLAY="wayland-0"
DISPLAY=":0"
