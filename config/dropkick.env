# Dropkick runtime environment — sourced by the systemd service.
# Copy to dropkick.local.env to override without touching version control.

# Install prefix used by bootstrap.sh
DROPKICK_PREFIX="${HOME}/.local"

# Preset / texture library roots
DROPKICK_PRESET_ROOT="${HOME}/.local/share/dropkick/presets"
DROPKICK_TEXTURE_ROOT="${HOME}/.local/share/dropkick/textures"
DROPKICK_PRESET_PACK="cream-of-the-crop"

# Audio capture device (empty = default/first device). Generic: any host device.
DROPKICK_AUDIO_SOURCE=""

# Phone remote
DROPKICK_REMOTE_PORT="8080"
DROPKICK_REMOTE_TOKEN=""

# Display for the HDMI output
DISPLAY=":0"
